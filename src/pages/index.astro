    border-bottom: 1px solid var(--grid-line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  @media (min-width: 768px) {
    .header-inner { height: 96px; }
  }

  .logo { display: flex; align-items: center; }

  .logo-img {
    height: 36px;
    width: auto;
    display: block;
    mix-blend-mode: multiply;
  }

  @media (min-width: 768px) {
    .logo-img { height: 48px; }
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 36px;
  }

  .nav-desktop a {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--ink);
    text-transform: uppercase;
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-desktop a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--olive);
    transition: width 0.3s ease;
  }

  .nav-desktop a:hover { color: var(--olive); }
  .nav-desktop a:hover::after { width: 100%; }

  .nav-cta {
    border: 1px solid var(--ink) !important;
    padding: 8px 20px !important;
    border-radius: 2px;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease !important;
  }

  .nav-cta::after { display: none !important; }

  .nav-cta:hover {
    background: var(--ink) !important;
    color: #ffffff !important;
    border-color: var(--ink) !important;
  }

  @media (min-width: 768px) {
    .nav-desktop { display: flex; }
    .hamburger   { display: none; }
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    background: rgba(247, 245, 240, 0.98);
    border-top: 1px solid var(--grid-line);
  }

  .mobile-menu.open { max-height: 360px; }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 16px 24px 28px;
  }

  .mobile-nav-link {
    font-family: var(--font-label);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 14px 0;
    border-bottom: 1px solid var(--grid-line);
    transition: color 0.3s ease;
  }

  .mobile-nav-link:last-child { border-bottom: none; }
  .mobile-nav-link:hover { color: var(--olive); }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
    padding: 120px 24px 100px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=1600&q=80');
    background-size: cover;
    background-position: center;
    opacity: 0.28;
  }

  /* (A) Signature grid overlay on hero */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.08;
    pointer-events: none;
    z-index: 1;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(28,27,25,0.55) 0%, rgba(28,27,25,0.3) 50%, rgba(28,27,25,0.65) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 780px;
    width: 100%;
    text-align: center;
  }

  .hero-label {
    font-family: var(--font-label);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 32px;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 9vw, 6.5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: 0.02em;
    margin-bottom: 36px;
    word-break: keep-all;
    overflow-wrap: normal;
  }

  .hero-desc {
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    color: rgba(255,255,255,0.6);
    line-height: 2;
    letter-spacing: 0.04em;
    margin-bottom: 64px;
  }

  /* Hero page-load sequence */
  .hero-seq {
    opacity: 0;
    transform: translateY(12px);
  }

  @keyframes heroFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-seq.loaded {
    animation: heroFadeUp 0.6s ease-out forwards;
  }

  .hero-seq-1.loaded { animation-delay: 0.1s; }
  .hero-seq-2.loaded { animation-delay: 0.2s; }
  .hero-seq-3.loaded { animation-delay: 0.35s; }
  .hero-seq-4.loaded { animation-delay: 0.5s; }

  @media (prefers-reduced-motion: reduce) {
    .hero-seq { opacity: 1; transform: none; }
    .hero-seq.loaded { animation: none; }
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }

  .btn-primary-dark {
    display: inline-block;
    background: #ffffff;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    padding: 16px 40px;
    border-radius: 2px;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .btn-primary-dark:hover {
    background: var(--olive);
    color: #ffffff;
    transform: translateY(-2px);
  }

  .btn-ghost {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.35);
    color: rgba(255,255,255,0.75);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    padding: 16px 40px;
    border-radius: 2px;
    transition: border-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.75);
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* ============================================================
     ON/OFF FLUX GRADIENT
     ============================================================ */
  .flux-gradient {
    height: 160px;
    background: linear-gradient(to bottom, var(--ink), var(--paper));
    pointer-events: none;
  }

  /* ============================================================
     SECTION DIVIDER тАФ GRID MOTIF (B)
     ============================================================ */
  .section-divider-grid {
    display: flex;
    align-items: center;
    height: 48px;
    padding: 0 24px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-divider-grid::before,
  .section-divider-grid::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--grid-line);
  }

  .grid-node {
    display: block;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  /* ============================================================
     INTRO
     ============================================================ */
  .intro-block {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-label {
    font-family: var(--font-label);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--grid-line);
    margin-bottom: 20px;
  }

  .intro-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 28px;
    line-height: 1.3;
  }

  .intro-body {
    font-size: 1rem;
    line-height: 2.2;
    color: var(--ink-soft);
    margin-bottom: 36px;
  }

  .intro-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--olive);
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--olive);
    padding-bottom: 2px;
    transition: opacity 0.3s ease;
  }

  .intro-link:hover { opacity: 0.65; }

  /* ============================================================
     CONCEPT
     ============================================================ */
  .concept-body {
    max-width: 840px;
    margin: 0 auto;
    text-align: center;
  }

  .concept-lead {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.5vw, 1.45rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 2.0;
    letter-spacing: 0.05em;
    margin-bottom: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--grid-line);
  }

  .concept-body p {
    font-size: 0.975rem;
    line-height: 2.2;
    color: var(--ink-soft);
    margin-bottom: 36px;
    word-break: keep-all;
    overflow-wrap: normal;
  }

  .concept-body p.concept-p--left {
    text-align: center;
    line-height: 2.0;
  }

  .concept-close {
    font-weight: 500;
    color: var(--ink) !important;
    margin-top: 24px;
    letter-spacing: 0.05em;
  }

  /* legacy - kept for safety */
  .layout-text {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 900px) {
    .layout-text {
      grid-template-columns: 260px 1fr;
      gap: 80px;
      align-items: start;
    }
  }

  .text-body p {
    font-size: 1rem;
    line-height: 2.1;
    color: var(--ink-soft);
    margin-bottom: 28px;
  }

  .text-link {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--olive);
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--olive);
    padding-bottom: 2px;
    transition: opacity 0.3s ease;
  }

  .text-link:hover { opacity: 0.6; }

  /* ============================================================
     PRICING
     ============================================================ */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }

  @media (min-width: 640px) {
    .pricing-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  /* (C) Pricing card hover grid */
  .pricing-card {
    border: 1px solid var(--grid-line);
    border-radius: 4px;
    padding: 48px 40px;
    background: var(--paper-alt);
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }

  .pricing-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .pricing-card:hover::before { opacity: 0.08; }

  .pricing-card--featured {
    background: var(--paper);
    border-color: var(--olive);
  }

  .pricing-card-head {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .pricing-plan {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 6px;
  }

  .pricing-sub {
    font-size: 0.8rem;
    color: var(--grid-line);
    letter-spacing: 0.05em;
  }

  .pricing-price {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 32px;
    white-space: nowrap;
  }

  .pricing-tax {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--grid-line);
    margin-left: 4px;
  }

  .pricing-includes {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-includes li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .check-icon {
    flex-shrink: 0;
    color: var(--olive);
  }

  .pricing-notes {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pricing-notes p {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .pricing-notes p::before {
    content: 'тАФ ';
    color: var(--olive);
  }

  /* ============================================================
     HOST PRESENCE
     ============================================================ */
  .host-presence {
    display: flex;
    gap: 16px;
    padding: 32px 28px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 4px;
    background: var(--paper-alt);
    align-self: stretch;
  }

  .host-presence-icon {
    flex-shrink: 0;
    color: var(--olive);
    padding-top: 2px;
  }

  .host-presence-heading {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 14px;
    letter-spacing: 0.02em;
  }

  .host-presence-text {
    font-size: 0.875rem;
    line-height: 1.9;
    color: var(--ink-soft);
    margin-bottom: 10px;
  }

  .host-presence-note {
    font-size: 0.78rem;
    color: var(--grid-line);
    line-height: 1.7;
    margin-top: 14px;
  }

  .btn-outline {
    display: inline-block;
    border: 1px solid var(--olive);
    color: var(--olive);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    padding: 16px 48px;
    border-radius: 2px;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .btn-outline:hover {
    background: var(--olive);
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* photo-placeholder */
  .photo-placeholder {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
  }

  .gallery-main .photo-placeholder {
    height: 100%;
    min-height: 260px;
  }

  @media (min-width: 768px) {
    .gallery-main .photo-placeholder { min-height: 460px; }
    .gallery-sub .photo-placeholder  { min-height: 215px; aspect-ratio: unset; }
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-main .photo-placeholder .gallery-img,
  .gallery-sub .photo-placeholder .gallery-img {
    position: absolute;
    inset: 0;
  }

  .gallery-sub .photo-placeholder {
    aspect-ratio: 4/3;
  }

  .photo-placeholder::after {
    display: none;
  }

  .photo-badge {
    display: none;
  }

  .offsite-photo {
    aspect-ratio: 4/3;
    min-height: 280px;
  }

  .operator-placeholder {
    aspect-ratio: 1;
    width: 120px;
  }

  @media (min-width: 768px) {
    .operator-placeholder {
      width: 140px;
    }
  }

  /* ============================================================
     OFFSITE
     ============================================================ */
  .offsite-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 900px) {
    .offsite-grid { grid-template-columns: 1fr 1fr 1fr; gap: 56px; align-items: start; }
  }

  .offsite-body {
    font-size: 1rem;
    line-height: 2.2;
    color: var(--ink-soft);
    margin-bottom: 40px;
  }

  .offsite-body--center {
    text-align: center;
  }

  .offsite-spec {
    display: grid;
    grid-template-columns: 5em 1fr;
    gap: 0;
  }

  .offsite-spec dt {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--grid-line);
    letter-spacing: 0.06em;
    padding: 14px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .offsite-spec dd {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.8;
    padding: 14px 0 14px 16px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .schedule-heading {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .schedule-note {
    font-size: 0.75rem;
    color: var(--grid-line);
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .schedule-footnote {
    font-size: 0.78rem;
    color: var(--grid-line);
    line-height: 1.7;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .schedule-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .schedule-list li {
    display: flex;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .schedule-time {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--olive);
    white-space: nowrap;
    padding-top: 2px;
    min-width: 40px;
  }

  .schedule-item {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  /* ============================================================
     VOICE
     ============================================================ */
  .voice-lead {
    text-align: center;
    font-size: 0.95rem;
    color: var(--ink-soft);
    letter-spacing: 0.05em;
    margin-bottom: 56px;
  }

  .voice-carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .voice-carousel {
    overflow: hidden;
    flex: 1;
  }

  .voice-track {
    display: flex;
    gap: 24px;
    will-change: transform;
  }

  /* (C) Voice card hover grid */
  .voice-card {
    background: var(--paper);
    border: 1px solid var(--grid-line);
    border-radius: 4px;
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .voice-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .voice-card:hover::before { opacity: 0.08; }

  .voice-icon-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 18px;
  }

  .voice-icon-ph {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #e8e4de;
  }

  .voice-icon-img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
  }

  .voice-body {
    font-size: 0.82rem;
    line-height: 1.85;
    color: var(--ink-soft);
    margin-bottom: 20px;
    flex: 1;
  }

  .voice-ratings {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.06);
    margin-bottom: 16px;
  }

  .voice-rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .voice-rating-label {
    font-size: 0.65rem;
    color: #bbb;
    letter-spacing: 0.03em;
    white-space: nowrap;
    min-width: 6.5em;
  }

  .voice-stars { display: flex; gap: 2px; }

  .star { font-size: 0.78rem; line-height: 1; }
  .star--filled { color: var(--olive); }
  .star--empty  { color: #ddd; }

  .voice-intent {
    font-size: 0.7rem;
    color: var(--olive);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 8px;
  }

  .voice-name {
    font-size: 0.7rem;
    color: #bbb;
    letter-spacing: 0.05em;
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 14px;
  }

  .carousel-arrow {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(0,0,0,0.15);
    border-radius: 50%;
    background: #ffffff;
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
  }

  .carousel-arrow:hover {
