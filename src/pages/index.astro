      <nav class="nav-desktop" aria-label="メインナビゲーション">
        <a href="#concept">SPACE</a>
        <a href="#pricing">PRICE</a>
        <a href="#access">ACCESS</a>
        <a href="#contact">CONTACT</a>
      </nav>
      <button class="hamburger" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <nav>
        <a href="#concept" class="mobile-nav-link">SPACE</a>
        <a href="#pricing" class="mobile-nav-link">PRICE</a>
        <a href="#access" class="mobile-nav-link">ACCESS</a>
        <a href="#contact" class="mobile-nav-link">CONTACT</a>
      </nav>
    </div>
  </header>

  <!-- ========== HERO ========== -->
