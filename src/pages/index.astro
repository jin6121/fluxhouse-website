</style>

<script>
  // Hero page-load sequence
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.hero-seq').forEach((el) => {
      el.classList.add('loaded');
    });
  });

  // Hamburger
  const hamburger = document.querySelector('.hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
      mobileMenu.setAttribute('aria-hidden', String(!isOpen));
    });
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  }

  // Map language toggle
  const mapBtns = document.querySelectorAll('.map-btn');
  const mapImgJa = document.getElementById('map-img-ja');
  const mapImgEn = document.getElementById('map-img-en');

  mapBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = (btn as HTMLElement).dataset.lang;
      mapBtns.forEach((b) => {
        b.classList.remove('map-btn--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('map-btn--active');
      btn.setAttribute('aria-pressed', 'true');
      if (lang === 'ja') {
        if (mapImgJa) (mapImgJa as HTMLElement).style.display = 'block';
        if (mapImgEn) (mapImgEn as HTMLElement).style.display = 'none';
      } else {
        if (mapImgEn) (mapImgEn as HTMLElement).style.display = 'block';
        if (mapImgJa) (mapImgJa as HTMLElement).style.display = 'none';
      }
    });
  });

  // Fade-in
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

  // ========== VOICE CAROUSEL ==========
  // 声を追加するにはこの配列に1ブロック足してください
  const voices = [
    { icon: '', body: '都心からアクセスしやすく、広くて綺麗で清潔。玄関の扉を開けたときの開放感が素敵で、非日常的な空間に足を踏み入れるワクワク感がありました。社内合宿でまた利用したいです。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: '役員 まつばらさん' },
    { icon: '', body: 'フルリモート中心の弊社ですが、オフラインだからこそ顔を合わせて活発に意見交換ができ、有意義な時間でした。開放的な気持ちのまま、みんなで自由にアイデアを出し合える素敵な会になりました。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: '開発チームリーダー いだ' },
    { icon: '', body: 'MTGから食事までの切り替えがスムーズで、メリハリをつけられる動線に感謝。BBQができたことで、流動的に全員の会話が生まれたのもよかったです。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: '人事担当 さっぷ' },
    { icon: '', body: '清潔感と開放感があり、快適に過ごせました。仕事に集中できる環境とリラックスできる空間が両立しており、企業研修やオフサイト、チームビルディングの場として非常に魅力的です。', satisfaction: 5, teamwork: 4, intent: 'ぜひまた利用したい', name: 'エンジニア N.K' },
    { icon: '', body: '流山という立地も含めて非常に素敵な場所でした。リビングが快適で、食器や照明等のこだわりを感じる空間です。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: 'マーケティングマネージャー HAL' },
    { icon: '', body: '綺麗な設備が整っていて、気持ちよく過ごせました。開放的なリビングが印象的でした。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: 'セールスマネージャー R' },
    { icon: '', body: '非常に快適で過ごしやすい場所でした。キッチンには包丁や豊富なお皿などすべてが揃っていて、生ごみ処理機もあり、ごみ捨てにも困りませんでした。', satisfaction: 4, teamwork: 5, intent: '機会があれば利用したい', name: 'カスタマーサクセス ぽぽいんこ' },
    { icon: '', body: '親身に準備してくださり、当日も最大限過ごしやすいように動いていただき、非常にいい空間でした。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: 'マーケティング み' },
    { icon: '', body: 'ありがとうございました。心地よい時間を過ごせました。', satisfaction: 5, teamwork: 4, intent: '機会があれば利用したい', name: '開発 りょうくん' },
    { icon: '', body: 'あたたかなお人柄のオーナーと、居心地のよい空間で、参加者全員が自然体で過ごすことができました。', satisfaction: 5, teamwork: 5, intent: '機会があれば利用したい', name: 'ご利用者さま' },
    { icon: '', body: '仕事でもプライベートでも、ぜひまた使わせていただきたいと感じました。キッチン用品も最新のものが揃っていて、とても魅力的でした。', satisfaction: 5, teamwork: 5, intent: 'ぜひまた利用したい', name: 'ご利用者さま（匿名希望）' },
  ];

  const voiceTrack = document.getElementById('voice-track') as HTMLElement | null;
  const voiceDotsEl = document.getElementById('voice-dots') as HTMLElement | null;
  const voiceCarousel = document.getElementById('voice-carousel') as HTMLElement | null;

  if (voiceTrack && voiceDotsEl && voiceCarousel) {
    const CARD_GAP = 24;
    let voiceIndex = 0;
    let voiceTimer: ReturnType<typeof setInterval> | null = null;
    let voiceHover = false;

    function getPerView(): number {
      if (window.innerWidth >= 1100) return 3;
      if (window.innerWidth >= 640) return 2;
      return 1;
    }

    function renderStars(n: number): string {
      return Array.from({ length: 5 }, (_, i) =>
        `<span class="star ${i < n ? 'star--filled' : 'star--empty'}">★</span>`
      ).join('');
    }

    function makeCard(v: typeof voices[0]): string {
      const icon = v.icon
        ? `<img src="${v.icon}" alt="" class="voice-icon-img">`
        : '<div class="voice-icon-ph"></div>';
      return `<div class="voice-card">
        <div class="voice-icon-wrap">${icon}</div>
        <p class="voice-body">${v.body}</p>
        <div class="voice-ratings">
          <div class="voice-rating-row">
            <span class="voice-rating-label">総合満足度</span>
            <span class="voice-stars">${renderStars(v.satisfaction)}</span>
          </div>
          <div class="voice-rating-row">
            <span class="voice-rating-label">チームの一体感</span>
            <span class="voice-stars">${renderStars(v.teamwork)}</span>
          </div>
          <div class="voice-intent">${v.intent}</div>
        </div>
        <p class="voice-name">${v.name}</p>
      </div>`;
    }

    // 末尾に先頭3枚をクローンして無限ループを実現
    const CLONE_COUNT = 3;
    voiceTrack.innerHTML =
      voices.map(makeCard).join('') +
      voices.slice(0, CLONE_COUNT).map(makeCard).join('');

    function getCardWidth(): number {
      const perView = getPerView();
      return (voiceCarousel!.offsetWidth - CARD_GAP * (perView - 1)) / perView;
    }

    function setCardWidths(): void {
      const w = getCardWidth();
      voiceTrack!.querySelectorAll('.voice-card').forEach(c => {
        (c as HTMLElement).style.width = w + 'px';
      });
    }

    function getMaxIndex(): number {
      return Math.max(0, voices.length - getPerView());
    }

    function applyOffset(index: number, animate: boolean): void {
      const offset = index * (getCardWidth() + CARD_GAP);
      voiceTrack!.style.transition = animate ? 'transform 0.5s ease' : 'none';
      voiceTrack!.style.transform = `translateX(-${offset}px)`;
    }

    function goToVoice(index: number, animate = true): void {
      voiceIndex = index;
      applyOffset(voiceIndex, animate);
      // dots always show real index (clamped 0–maxIndex)
      updateVoiceDots(Math.min(voiceIndex, getMaxIndex()));
    }

    // クローンゾーンに入ったら静かに先頭へスナップ
    voiceTrack!.addEventListener('transitionend', () => {
      if (voiceIndex >= voices.length) {
        voiceIndex = voiceIndex - voices.length;
        applyOffset(voiceIndex, false);
        updateVoiceDots(Math.min(voiceIndex, getMaxIndex()));
      }
    });

    function updateVoiceDots(active: number): void {
      const total = getMaxIndex() + 1;
      voiceDotsEl!.innerHTML = Array.from({ length: total }, (_, i) =>
        `<button class="carousel-dot${i === active ? ' carousel-dot--active' : ''}" data-i="${i}" aria-label="${i + 1}ページ目"></button>`
      ).join('');
      voiceDotsEl!.querySelectorAll('.carousel-dot').forEach(dot => {
        dot.addEventListener('click', () => goToVoice(parseInt((dot as HTMLElement).dataset.i || '0')));
      });
    }

    function startVoiceAuto(): void {
      if (voiceTimer) clearInterval(voiceTimer);
      voiceTimer = setInterval(() => {
        if (!voiceHover) {
          // 無限ループ：maxIndexを超えてクローンへ進み、transitionendでスナップ
          goToVoice(voiceIndex + 1);
        }
      }, 5500);
    }

    setCardWidths();
    goToVoice(0, false);
    startVoiceAuto();

    window.addEventListener('resize', () => {
      setCardWidths();
      goToVoice(Math.min(voiceIndex, getMaxIndex()), false);
    });

    const carouselWrap = document.querySelector('.voice-carousel-wrap');
    if (carouselWrap) {
      carouselWrap.addEventListener('mouseenter', () => { voiceHover = true; });
      carouselWrap.addEventListener('mouseleave', () => { voiceHover = false; });
    }

    const prevBtn = document.getElementById('voice-prev');
    const nextBtn = document.getElementById('voice-next');
    if (prevBtn) prevBtn.addEventListener('click', () => {
      goToVoice(voiceIndex <= 0 ? getMaxIndex() : voiceIndex - 1);
    });
    if (nextBtn) nextBtn.addEventListener('click', () => {
      goToVoice(voiceIndex + 1);
    });
  }
</script>
