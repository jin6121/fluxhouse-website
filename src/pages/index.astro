---
import Layout from '../layouts/Layout.astro';

interface NoteItem {
  title: string;
  link: string;
  pubDate: string;
  description: string;
}

let noteItems: NoteItem[] = [];
try {
  const res = await fetch('https://note.com/jin_sariimama/m/mbada4e66a2a3/rss');
  const xml = await res.text();
  const items = xml.match(/<item>([\s\S]*?)<\/item>/g) || [];
  noteItems = items.slice(0, 3).map((item) => {
    const title = item.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1] || item.match(/<title>(.*?)<\/title>/)?.[1] || '';
    const link = item.match(/<link>(.*?)<\/link>/)?.[1] || '';
    const pubDate = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] || '';
    const description = item.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>/)?.[1] || item.match(/<description>(.*?)<\/description>/)?.[1] || '';
    const date = pubDate ? new Date(pubDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
    const plainDesc = description.replace(/<[^>]+>/g, '').slice(0, 80);
    return { title, link, pubDate: date, description: plainDesc };
  });
} catch (e) {
  noteItems = [];
}
